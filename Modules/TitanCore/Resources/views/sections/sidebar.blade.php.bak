{{-- Titan Core Sidebar --}}
@php
    $user = auth()->user();
    $roles = function_exists('user_roles') ? user_roles() : [];

    // Preserve existing permission logic
    $canViewTitanCore = $user && $user->can('titancore.view');
    $canManageTitanCore = $user && $user->can('titancore.manage');

    // Combine permissions + roles to decide visibility
    $showTitanCoreMenu = $canViewTitanCore && in_array('admin', $roles);

    $titanCoreMenuOpen = request()->routeIs('titancore.*') ? 'menu-open' : '';
    $titanCoreLinkActive = request()->routeIs('titancore.*') ? 'active' : '';
@endphp

@if($showTitanCoreMenu)
    <li class="nav-item has-treeview {{ $titanCoreMenuOpen }}">
        <a href="javascript:void(0);" class="nav-link {{ $titanCoreLinkActive }}">
            <i class="fa fa-brain nav-icon"></i>
            <p>
                {{ __('Titan Core') }}
                <i class="right fa fa-angle-left"></i>
            </p>
        </a>

        <ul class="nav nav-treeview">
            @if($canManageTitanCore)
                <li class="nav-item">
                    <a href="{{ route('titancore.settings.index') }}"
                       class="nav-link text-sm {{ request()->routeIs('titancore.settings.*') ? 'active' : '' }}">
                        <i class="fa fa-cogs nav-icon"></i>
                        <p>{{ __('Settings') }}</p>
                    </a>
                </li>
            @endif

            <li class="nav-item">
                <a href="{{ route('titancore.usage.index') }}"
                   class="nav-link text-sm {{ request()->routeIs('titancore.usage.*') ? 'active' : '' }}">
                    <i class="fa fa-chart-line nav-icon"></i>
                    <p>{{ __('Usage & Billing') }}</p>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ route('titancore.health') }}"
                   class="nav-link text-sm {{ request()->routeIs('titancore.health') ? 'active' : '' }}">
                    <i class="fa fa-heartbeat nav-icon"></i>
                    <p>{{ __('Health') }}</p>
                </a>
            </li>
        </ul>
    </li>
@endif