APP_NAME=WORKSUITE-SAAS
APP_KEY=base64:wID/CO/WkfE3yoWpQOoy15de8FtOpvC3dM/z5FuHiEU=

# Do not change APP_ENV to anything else. It will affect emailing from admin panel
# and other configuration from databse and system may crash
APP_ENV=codecanyon
APP_DEBUG=false

APP_URL=http://localhost

#For redirect to https
REDIRECT_HTTPS=false

MAIL_FROM_VERIFIED_EMAIL=true

# Add here if you main app is installed on some subdomain
MAIN_APPLICATION_SUBDOMAIN=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=Raja
DB_USERNAME=root
DB_PASSWORD=1234

# ─────────────────────────────────────────────────────────────────────────────
# BROADCASTING — Laravel Reverb (self-hosted WebSocket)
# Run: php artisan reverb:start
# ─────────────────────────────────────────────────────────────────────────────
BROADCAST_DRIVER=reverb

REVERB_APP_ID=worksuite
REVERB_APP_KEY=worksuite-reverb-key
REVERB_APP_SECRET=worksuite-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Reverb server bind address (0.0.0.0 listens on all interfaces)
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# For horizontal scaling via Redis pub/sub (set to true + configure Redis)
REVERB_SCALING_ENABLED=false

# Laravel Mix env vars (passed to webpack)
MIX_REVERB_APP_KEY="${REVERB_APP_KEY}"
MIX_REVERB_HOST="${REVERB_HOST}"
MIX_REVERB_PORT="${REVERB_PORT}"
MIX_REVERB_SCHEME="${REVERB_SCHEME}"

# Legacy Pusher (kept for backward compat — leave blank if using Reverb)
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ─────────────────────────────────────────────────────────────────────────────
# LARAVEL MCP — Model Context Protocol server
# Exposes tools/resources to AI assistants (Claude, Copilot, etc.)
# ─────────────────────────────────────────────────────────────────────────────
MCP_ENABLED=true
MCP_SERVER_NAME="Worksuite SaaS"
MCP_SERVER_VERSION="1.0.0"
# Auth token required for MCP requests (set a strong random value)
MCP_AUTH_TOKEN=

# -----------------------------------------------------------------------
# TitanIntegrations — Third-Party Connections
# -----------------------------------------------------------------------

# Google (Calendar, Sheets, Business Profile) — shared OAuth app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/account/titan-integrations/google_calendar/oauth/callback"

# Microsoft (Outlook Calendar, Teams)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI="${APP_URL}/account/titan-integrations/outlook_calendar/oauth/callback"
MICROSOFT_TENANT_ID=common

# Xero
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI="${APP_URL}/account/titan-integrations/xero/oauth/callback"

# QuickBooks
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI="${APP_URL}/account/titan-integrations/quickbooks/oauth/callback"
QUICKBOOKS_SANDBOX=false

# MYOB
MYOB_CLIENT_ID=
MYOB_CLIENT_SECRET=
MYOB_REDIRECT_URI="${APP_URL}/account/titan-integrations/myob/oauth/callback"

# HubSpot (API key — or use OAuth via portal)
HUBSPOT_API_KEY=

# Mailchimp (API key)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# Slack (incoming webhook URL — or per-tenant BYO)
SLACK_WEBHOOK_URL=

# Google Chat
GOOGLE_CHAT_WEBHOOK_URL=

# Microsoft Teams
TEAMS_WEBHOOK_URL=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI="${APP_URL}/account/titan-integrations/salesforce/oauth/callback"

# ServiceM8
SERVICEM8_CLIENT_ID=
SERVICEM8_CLIENT_SECRET=
SERVICEM8_REDIRECT_URI="${APP_URL}/account/titan-integrations/servicem8/oauth/callback"

# Airtasker / Hipages (API key)
AIRTASKER_API_KEY=
HIPAGES_API_KEY=

# TitanIntegrations REST API
TITAN_API_RATE_LIMIT=60
TITAN_API_TOKEN_EXPIRY=365
